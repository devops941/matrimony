// This is your Prisma schema file
// Write your models here

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
  output               = "../prisma_client"
}

model CompanyProfile {
  id                    String @id @default(auto()) @map("_id") @db.ObjectId
  companyName           String
  address               String
  phone                 String
  email                 String
  whatsappNumber        String
  city                  String
  state                 String
  country               String
  gstNumber             String @default("")
  incorporationDetails  String @default("")
  companyLogoUrl        String  @default("")
}

model NakshatraMatrix {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  matrix       Json
  isCustomized Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

model Community {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  isActive Boolean @default(true)
}

model Nakshatra {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String  @unique
  isActive Boolean @default(true)
}

model Porutham {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  key         String  @unique   // e.g. "Dina"
  label       String            // e.g. "Dina Porutham (Longevity & Health)"
  description String            // what it governs
  orderIndex  Int               // 1-10 for display order
  isEnabled   Boolean @default(true)
}

model JobCategory {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String  @unique
  isActive Boolean @default(true)
}

model Profile {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  registrationId          String   @unique
  password                String
  name                    String
  gender                  String   // "Male" | "Female"
  age                     Int
  height                  String
  weight                  String   @default("")
  location                String
  community               String
  nakshatra               String
  rasi                    String
  education               String
  jobType                 String
  annualIncomeLakhs       Int
  bio                     String
  avatarUrl               String
  chevvaiDosham           String   // "Yes" | "No" | "Unknown"
  birthDate               String
  birthTime               String
  birthPlace              String
  
  // New Personal Details
  bloodGroup              String   @default("")
  diet                    String   @default("Vegetarian")
  maritalStatus           String   @default("Never Married")
  motherTongue            String   @default("Tamil")
  contactNumber           String   @default("")
  email                   String   @default("")
  
  // New Family Details
  fatherName              String   @default("")
  fatherOccupation        String   @default("")
  motherName              String   @default("")
  motherOccupation        String   @default("")
  siblings                Int      @default(0)
  
  approvedByAdmin         Boolean  @default(true)
  confirmedMatchedWith    String?

  // Expectations (Flattened for prisma-client-py support)
  expMinAge               Int      @default(18)
  expMaxAge               Int      @default(60)
  expAcceptedCommunities  String[]
  expAcceptedJobTypes     String[]
  expMinAnnualIncomeLakhs Int      @default(0)
  expAcceptedLocations    String[]
  expGoldExpectedSovereigns Int    @default(0)
  expHouseOwnedRequired   Boolean  @default(false)
  
  // New Expectations
  expMinHeight            String   @default("")
  expMaxHeight            String   @default("")
  expPreferredEducation   String   @default("")
}


